<Window x:Class="Xhair.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Xhair"
        xmlns:models="clr-namespace:Xhair.Models"
        mc:Ignorable="d"
        Title="Xhair Settings"
        Height="560"
        Width="420"
        Background="#111418"
        Foreground="#E7ECF2"
        PreviewKeyDown="OnHotkeyPreviewKeyDown">
    <Window.Resources>
        <local:ImagePathToSourceConverter x:Key="ImagePathToSource" />
        <local:StringToVisibilityConverter x:Key="StringToVisibility" />
        <local:CrosshairShapeVisibilityConverter x:Key="ShapeVisibility" />
        <local:HexToBrushConverter x:Key="HexToBrush" />
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#171C22" CornerRadius="12" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Xhair" FontSize="18" FontWeight="Bold" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Update"
                            Margin="0,0,8,0"
                            Click="OnUpdateClicked"
                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibility}}" />
                    <ToggleButton Content="Crosshair Enabled"
                                  IsChecked="{Binding IsEnabled}"
                                  Padding="12,6"
                                  Background="#253140"
                                  BorderBrush="#2E3A46"
                                  Foreground="#E7ECF2" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Background="#171C22" BorderBrush="#2E3A46">
            <TabItem Header="Profiles">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="Profiles" FontWeight="Bold" Margin="0,0,0,8" />
                        <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfileName}" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="Load" Width="80" Margin="0,0,8,0" Click="OnLoadProfile" />
                            <Button Content="Save" Width="80" Click="OnSaveProfile" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBox Width="200" Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Content="Add" Width="80" Margin="8,0,0,0" Click="OnAddProfile" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBox Width="200" Text="{Binding RenameProfileName, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Content="Rename" Width="80" Margin="8,0,0,0" Click="OnRenameProfile" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Duplicate" Width="90" Margin="0,0,8,0" Click="OnDuplicateProfile" />
                            <Button Content="Import" Width="80" Margin="0,0,8,0" Click="OnImportProfile" />
                            <Button Content="Export" Width="80" Click="OnExportProfile" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Editor">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Profile" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox Width="160"
                                  ItemsSource="{Binding Profiles}"
                                  SelectedItem="{Binding SelectedProfileName}"
                                  SelectionChanged="OnEditorProfileChanged"
                                  Margin="0,0,12,0" />
                        <ToggleButton Content="Guidelines"
                                      IsChecked="{Binding ShowEditorGuides}"
                                      Padding="10,4"
                                      Margin="0,0,8,0" />
                        <ToggleButton Content="Draw"
                                      Padding="10,4"
                                      Margin="0,0,8,0"
                                      Checked="OnDrawModeChecked"
                                      Unchecked="OnDrawModeUnchecked" />
                        <Button Content="Apply" Margin="0,0,8,0" Click="OnApplyEditor" />
                        <Button Content="Remove Image" Margin="0,0,8,0" Click="OnRemoveImage" />
                        <Button Content="Clear Drawing" Click="OnClearDrawing" />
                    </StackPanel>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="240" />
                        </Grid.ColumnDefinitions>
                        <Border Background="#0E1116" CornerRadius="10" BorderBrush="#2E3A46" BorderThickness="1" Margin="0,0,12,0">
                            <Canvas x:Name="EditorCanvas"
                                    AllowDrop="True"
                                    Background="#0E1116"
                                    DragOver="OnEditorDragOver"
                                    Drop="OnEditorDrop"
                                    SizeChanged="OnEditorSizeChanged"
                                    MouseLeftButtonDown="OnEditorMouseDown"
                                    MouseMove="OnEditorMouseMove"
                                    MouseLeftButtonUp="OnEditorMouseUp">
                                <Line x:Name="VerticalGuide"
                                      Stroke="#40FFFFFF"
                                      StrokeThickness="1"
                                      Visibility="{Binding ShowEditorGuides, Converter={StaticResource BoolToVisibility}}" />
                                <Line x:Name="HorizontalGuide"
                                      Stroke="#40FFFFFF"
                                      StrokeThickness="1"
                                      Visibility="{Binding ShowEditorGuides, Converter={StaticResource BoolToVisibility}}" />

                                <Rectangle x:Name="PreviewLeft"
                                           Width="{Binding EditLineLength}"
                                           Height="{Binding EditThickness}"
                                           Fill="{Binding EditCrosshairBrush}"
                                           Opacity="{Binding EditOpacity}" />
                                <Rectangle x:Name="PreviewRight"
                                           Width="{Binding EditLineLength}"
                                           Height="{Binding EditThickness}"
                                           Fill="{Binding EditCrosshairBrush}"
                                           Opacity="{Binding EditOpacity}" />
                                <Rectangle x:Name="PreviewTop"
                                           Width="{Binding EditThickness}"
                                           Height="{Binding EditLineLength}"
                                           Fill="{Binding EditCrosshairBrush}"
                                           Opacity="{Binding EditOpacity}" />
                                <Rectangle x:Name="PreviewBottom"
                                           Width="{Binding EditThickness}"
                                           Height="{Binding EditLineLength}"
                                           Fill="{Binding EditCrosshairBrush}"
                                           Opacity="{Binding EditOpacity}" />
                                <Ellipse x:Name="PreviewDot"
                                         Width="{Binding EditDotSize}"
                                         Height="{Binding EditDotSize}"
                                         Fill="{Binding EditCrosshairBrush}"
                                         Opacity="{Binding EditOpacity}" />

                                <Image x:Name="PreviewImage"
                                       Source="{Binding EditorImagePath, Converter={StaticResource ImagePathToSource}}"
                                       Visibility="{Binding EditorImagePath, Converter={StaticResource StringToVisibility}}"
                                       Canvas.Left="{Binding EditorImageX}"
                                       Canvas.Top="{Binding EditorImageY}"
                                       Stretch="None"
                                       Cursor="SizeAll"
                                       MouseLeftButtonDown="OnImageMouseDown"
                                       MouseMove="OnImageMouseMove"
                                       MouseLeftButtonUp="OnImageMouseUp" />
                            </Canvas>
                        </Border>
                        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0">
                                <TextBlock Text="Presets" FontWeight="Bold" Margin="0,0,0,8" />
                                <ListBox ItemsSource="{Binding Presets}"
                                         SelectionChanged="OnPresetSelected"
                                         BorderBrush="#2E3A46"
                                         Background="#0E1116"
                                         Margin="0,0,0,12">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="6">
                                                <Border Width="48" Height="48" Background="#111418" CornerRadius="6" Margin="0,0,8,0">
                                                    <Canvas Width="48" Height="48">
                                                        <Rectangle Width="{Binding Settings.LineLength}"
                                                                   Height="{Binding Settings.Thickness}"
                                                                   Fill="{Binding Settings.ColorHex, Converter={StaticResource HexToBrush}}"
                                                                   Opacity="{Binding Settings.Opacity}"
                                                                   Canvas.Left="4"
                                                                   Canvas.Top="23"
                                                                   Visibility="{Binding Settings.Shape, Converter={StaticResource ShapeVisibility}, ConverterParameter=Cross}" />
                                                        <Rectangle Width="{Binding Settings.LineLength}"
                                                                   Height="{Binding Settings.Thickness}"
                                                                   Fill="{Binding Settings.ColorHex, Converter={StaticResource HexToBrush}}"
                                                                   Opacity="{Binding Settings.Opacity}"
                                                                   Canvas.Left="24"
                                                                   Canvas.Top="23"
                                                                   Visibility="{Binding Settings.Shape, Converter={StaticResource ShapeVisibility}, ConverterParameter=Cross}" />
                                                        <Rectangle Width="{Binding Settings.Thickness}"
                                                                   Height="{Binding Settings.LineLength}"
                                                                   Fill="{Binding Settings.ColorHex, Converter={StaticResource HexToBrush}}"
                                                                   Opacity="{Binding Settings.Opacity}"
                                                                   Canvas.Left="23"
                                                                   Canvas.Top="4"
                                                                   Visibility="{Binding Settings.Shape, Converter={StaticResource ShapeVisibility}, ConverterParameter=Cross}" />
                                                        <Rectangle Width="{Binding Settings.Thickness}"
                                                                   Height="{Binding Settings.LineLength}"
                                                                   Fill="{Binding Settings.ColorHex, Converter={StaticResource HexToBrush}}"
                                                                   Opacity="{Binding Settings.Opacity}"
                                                                   Canvas.Left="23"
                                                                   Canvas.Top="24"
                                                                   Visibility="{Binding Settings.Shape, Converter={StaticResource ShapeVisibility}, ConverterParameter=Cross}" />
                                                        <Ellipse Width="{Binding Settings.DotSize}"
                                                                 Height="{Binding Settings.DotSize}"
                                                                 Fill="{Binding Settings.ColorHex, Converter={StaticResource HexToBrush}}"
                                                                 Opacity="{Binding Settings.Opacity}"
                                                                 Canvas.Left="20"
                                                                 Canvas.Top="20"
                                                                 Visibility="{Binding Settings.Shape, Converter={StaticResource ShapeVisibility}, ConverterParameter=Dot}" />
                                                        <Ellipse Width="{Binding Settings.LineLength}"
                                                                 Height="{Binding Settings.LineLength}"
                                                                 Stroke="{Binding Settings.ColorHex, Converter={StaticResource HexToBrush}}"
                                                                 StrokeThickness="{Binding Settings.Thickness}"
                                                                 Opacity="{Binding Settings.Opacity}"
                                                                 Canvas.Left="14"
                                                                 Canvas.Top="14"
                                                                 Visibility="{Binding Settings.Shape, Converter={StaticResource ShapeVisibility}, ConverterParameter=Circle}" />
                                                        <Line X1="12" Y1="12" X2="36" Y2="36"
                                                              Stroke="{Binding Settings.ColorHex, Converter={StaticResource HexToBrush}}"
                                                              StrokeThickness="{Binding Settings.Thickness}"
                                                              Opacity="{Binding Settings.Opacity}"
                                                              Visibility="{Binding Settings.Shape, Converter={StaticResource ShapeVisibility}, ConverterParameter=X}" />
                                                        <Line X1="12" Y1="36" X2="36" Y2="12"
                                                              Stroke="{Binding Settings.ColorHex, Converter={StaticResource HexToBrush}}"
                                                              StrokeThickness="{Binding Settings.Thickness}"
                                                              Opacity="{Binding Settings.Opacity}"
                                                              Visibility="{Binding Settings.Shape, Converter={StaticResource ShapeVisibility}, ConverterParameter=X}" />
                                                        <Rectangle Width="24"
                                                                   Height="{Binding Settings.Thickness}"
                                                                   Fill="{Binding Settings.ColorHex, Converter={StaticResource HexToBrush}}"
                                                                   Opacity="{Binding Settings.Opacity}"
                                                                   Canvas.Left="12"
                                                                   Canvas.Top="18"
                                                                   Visibility="{Binding Settings.Shape, Converter={StaticResource ShapeVisibility}, ConverterParameter=T}" />
                                                    </Canvas>
                                                </Border>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Text="Appearance" FontWeight="Bold" Margin="0,0,0,8" />
                                <TextBlock Text="Shape" />
                                <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding EditShape}">
                                    <ComboBoxItem Content="Cross" Tag="{x:Static models:CrosshairShape.Cross}" />
                                    <ComboBoxItem Content="Dot" Tag="{x:Static models:CrosshairShape.Dot}" />
                                    <ComboBoxItem Content="Circle" Tag="{x:Static models:CrosshairShape.Circle}" />
                                    <ComboBoxItem Content="X" Tag="{x:Static models:CrosshairShape.X}" />
                                    <ComboBoxItem Content="T" Tag="{x:Static models:CrosshairShape.T}" />
                                </ComboBox>
                                <TextBlock Text="Color (Hex)" />
                                <TextBox Text="{Binding EditColorHex, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Outline Color (Hex)" Margin="0,8,0,0" />
                                <TextBox Text="{Binding EditOutlineColorHex, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Outline Enabled" IsChecked="{Binding EditOutlineEnabled}" Margin="0,8,0,0" />
                                <StackPanel Margin="0,6,0,0">
                                    <TextBlock Text="Outline Thickness" />
                                    <Slider Minimum="0" Maximum="6" Value="{Binding EditOutlineThickness, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding EditOutlineThickness, StringFormat=F0}" />
                                </StackPanel>
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="Line Length" />
                                    <Slider Minimum="2" Maximum="40" Value="{Binding EditLineLength, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding EditLineLength, StringFormat=F0}" />
                                </StackPanel>
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="Thickness" />
                                    <Slider Minimum="1" Maximum="10" Value="{Binding EditThickness, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding EditThickness, StringFormat=F0}" />
                                </StackPanel>
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="Gap" />
                                    <Slider Minimum="0" Maximum="20" Value="{Binding EditGap, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding EditGap, StringFormat=F0}" />
                                </StackPanel>
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="Dot Size" />
                                    <Slider Minimum="0" Maximum="12" Value="{Binding EditDotSize, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding EditDotSize, StringFormat=F0}" />
                                </StackPanel>
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="Opacity" />
                                    <Slider Minimum="0.1" Maximum="1" Value="{Binding EditOpacity, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding EditOpacity, StringFormat=F2}" />
                                </StackPanel>
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="Offset X" />
                                    <Slider Minimum="-100" Maximum="100" Value="{Binding EditOffsetX, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding EditOffsetX, StringFormat=F0}" />
                                </StackPanel>
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="Offset Y" />
                                    <Slider Minimum="-100" Maximum="100" Value="{Binding EditOffsetY, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding EditOffsetY, StringFormat=F0}" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                    <TextBlock Grid.Row="2"
                               Margin="0,10,0,0"
                               Opacity="0.7"
                               Text="Drag and drop a PNG to preview and reposition. Draw mode lets you sketch in the editor." />
                </Grid>
            </TabItem>
            <TabItem Header="Startup">
                <StackPanel Margin="16">
                    <TextBlock Text="Launch Behavior" FontWeight="Bold" Margin="0,0,0,8" />
                    <CheckBox Content="Start minimized to tray"
                              IsChecked="{Binding StartInTray}" />
                    <CheckBox Content="Start crosshair on app launch"
                              IsChecked="{Binding StartEnabledOnLaunch}" />
                    <CheckBox Content="Launch with Windows"
                              Margin="0,8,0,0"
                              IsChecked="{Binding StartWithWindows}"
                              Checked="OnStartupToggleChanged"
                              Unchecked="OnStartupToggleChanged" />
                    <CheckBox Content="Apply changes live"
                              Margin="0,8,0,0"
                              IsChecked="{Binding LivePreviewEnabled}" />
                </StackPanel>
            </TabItem>
            <TabItem Header="Hotkeys">
                <StackPanel Margin="16">
                    <TextBlock Text="Hotkeys" FontWeight="Bold" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Toggle Crosshair" Width="150" VerticalAlignment="Center" />
                        <TextBox Width="120" Text="{Binding ToggleHotkey}" IsReadOnly="True" Margin="0,0,8,0" />
                        <Button Content="Set" Click="OnSetToggleHotkey" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Cycle Profiles" Width="150" VerticalAlignment="Center" />
                        <TextBox Width="120" Text="{Binding CycleHotkey}" IsReadOnly="True" Margin="0,0,8,0" />
                        <Button Content="Set" Click="OnSetCycleHotkey" />
                    </StackPanel>
                    <TextBlock x:Name="HotkeyCaptureHint" Opacity="0.7" />
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
